{
  "manifest_version": 3,
  "name": "EverFern Web Automation",
  "version": "1.0.0",
  "description": "Enhanced web automation extension for Playwright-based browser automation",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*"
  ],
  "externally_connectable": {
    "matches": ["<all_urls>"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "automation.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "EverFern Web Automation",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
