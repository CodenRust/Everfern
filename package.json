{
  "name": "desktop",
  "version": "0.1.1",
  "description": "EverFern — Your autonomous AI workplace agent.",
  "author": "Everfern Community",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev:electron": "tsc -p tsconfig.electron.json -w",
    "prebuild:electron-ts": "node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\"",
    "build:electron-ts": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:electron-ts && cross-env NEXT_TELEMETRY_DISABLED=1 UV_THREADPOOL_SIZE=4 concurrently -k \"next dev --webpack -p 3001\" \"wait-on tcp:3001 && electron .\"",
    "build:next": "next build",
    "build:electron": "npm run build:electron-ts && electron-builder",
    "build": "npm run build:next && npm run build:electron-ts && electron-builder",
    "rebuild:electron": "cross-env npm_config_runtime=electron npm_config_target=41.0.3 npm_config_disturl=https://electronjs.org/headers npm rebuild better-sqlite3 sqlite-vec uiohook-napi @jitsi/robotjs sharp --build-from-source",
    "start": "electron-forge start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "build": {
    "appId": "com.everfern.desktop",
    "productName": "EverFern",
    "copyright": "Copyright © 2026 EverFern",
    "npmRebuild": true,
    "icon": "public/images/logos/everfern.ico",
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "everfern-app",
        "schemes": [
          "everfern-app"
        ]
      }
    ],
    "files": [
      "dist-electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.d.ts"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/images/logos/everfern.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nativeRebuilder": "legacy",
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EverFern",
      "installerIcon": "public/images/logos/everfern.ico",
      "uninstallerIcon": "public/images/logos/everfern.ico",
      "installerHeaderIcon": "public/images/logos/everfern.ico",
      "license": "build/license.txt"
    }
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.24",
    "@assistant-ui/react-markdown": "^0.12.8",
    "@heroicons/react": "^2.2.0",
    "@ibm-cloud/watsonx-ai": "^1.7.11",
    "@jitsi/robotjs": "^0.6.21",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@livekit/components-react": "^2.9.20",
    "@mariozechner/pi-coding-agent": "^0.63.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/sqlite3": "^3.1.11",
    "ansi-to-react": "^6.2.6",
    "better-sqlite3": "^12.8.0",
    "canvas": "^3.2.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.4",
    "discord.js": "^14.14.1",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "ibm-cloud-sdk-core": "^5.4.11",
    "js-beautify": "^1.15.4",
    "livekit-client": "^2.18.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.1",
    "node-gyp": "^12.2.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.34.0",
    "parse-diff": "^0.11.1",
    "picomatch": "^4.0.4",
    "play-sound": "^1.1.6",
    "playwright": "^1.59.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "screenshot-desktop": "^1.15.3",
    "search-engine-nodejs": "^1.0.9",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7",
    "sqlite3": "^6.0.1",
    "string-similarity": "^4.0.4",
    "tailwind-merge": "^3.5.0",
    "tiktoken": "^1.0.22",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.10",
    "uiohook-napi": "^1.5.5",
    "winreg": "^1.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^0.22.35",
    "@types/dom-mediacapture-record": "^1.0.22",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^20",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/play-sound": "^1.1.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/string-similarity": "^4.0.2",
    "@types/winreg": "^1.2.36",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  }
}
