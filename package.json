{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev:electron": "tsc -p tsconfig.electron.json -w",
    "prebuild:electron-ts": "node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\"",
    "build:electron-ts": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:electron-ts && cross-env NEXT_TELEMETRY_DISABLED=1 UV_THREADPOOL_SIZE=4 concurrently -k \"next dev --webpack -p 3001\" \"wait-on tcp:3001 && electron .\"",
    "build:next": "next build",
    "build:electron": "npm run build:electron-ts && electron-builder",
    "build": "npm run build:next && npm run build:electron",
    "rebuild:electron": "cross-env npm_config_runtime=electron npm_config_target=34.0.0 npm_config_disturl=https://electronjs.org/headers npm rebuild better-sqlite3 sqlite-vec --build-from-source",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.24",
    "@assistant-ui/react-markdown": "^0.12.8",
    "@heroicons/react": "^2.2.0",
    "@jitsi/robotjs": "^0.6.21",
    "@langchain/community": "^1.1.25",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@livekit/components-react": "^2.9.20",
    "@mariozechner/pi-coding-agent": "^0.63.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/sqlite3": "^3.1.11",
    "better-sqlite3": "^12.8.0",
    "canvas": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.4",
    "framer-motion": "^12.38.0",
    "livekit-client": "^2.18.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "parse-diff": "^0.11.1",
    "play-sound": "^1.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "screenshot-desktop": "^1.15.3",
    "search-engine-nodejs": "^1.0.9",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "tiktoken": "^1.0.22",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/play-sound": "^1.1.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
