        class="border border-[#e5e7eb] rounded-lg px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400"
      >
        Always allow
      </button>
      <button
        aria-label="Allow local execution once"
        class="bg-[#1a1a1a] text-white rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-[#2a2a2a] transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-800"
      >
        Allow once
      </button>
    </div>
  </div>
  <div
    class="flex items-center gap-2 mt-3 text-amber-500 text-sm italic"
  >
    <svg
      class="w-4 h-4 animate-spin"
      fill="none"
      stroke-dasharray="4 4"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle
        class="opacity-25"
        cx="12"
        cy="12"
        r="10"
        stroke="currentColor"
