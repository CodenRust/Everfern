      >
        <code
          class="font-mono text-sm text-[#6366f1] whitespace-pre-wrap"
        >
          Get-ChildItem -Path C:\\\\ -Recurse
        </code>
      </div>
    </div>
    <div
      class="mt-4 flex justify-end gap-2"
    >
      <button
        aria-label="Deny local execution"
